#!/usr/bin/env bash

sudo yabai --load-sa
yabai -m signal --add event=dock_did_restart action="sudo yabai --load-sa"

for _ in $(seq $(yabai -m query --spaces | jq '. | length') 3); do
    yabai -m space --create
done

yabai -m config layout bsp
yabai -m config window_placement second_child
yabai -m config window_gap 0

yabai -m rule --add app="^Ghostty$" space=1
yabai -m rule --add app="^Zen$" space=2
yabai -m rule --add app="^Cinny$" space=3
yabai -m rule --add app="^Signal$" space=4
yabai -m rule --add app="^Discord$" space=4
yabai -m rule --add app="^Telegram$" space=4

yabai -m rule --apply
