#!/usr/bin/env bash

sudo yabai --load-sa
yabai -m signal --add event=dock_did_restart action="sudo yabai --load-sa"

space_count=$(yabai -m query --spaces | jq '. | length')
while [ "$space_count" -lt 4 ]; do
    yabai -m space --create
    space_count=$((space_count + 1))
done
while [ "$space_count" -gt 4 ]; do
    yabai -m space --destroy "$space_count"
    space_count=$((space_count - 1))
done

yabai -m config layout bsp
yabai -m config window_placement second_child
yabai -m config window_gap 0

yabai -m config mouse_follows_focus off
yabai -m config focus_follows_mouse off
yabai -m config mouse_modifier      fn
yabai -m config mouse_action1       move
yabai -m config mouse_action2       resize
yabai -m config mouse_drop_action   swap

yabai -m rule --add app="^(System Settings|Finder|Calculator|Archive Utility)$" manage=off

yabai -m rule --add label=terminal app="^Ghostty$" space=1
yabai -m rule --add label=browser  app="^Zen$"     space=2
yabai -m rule --add label=cinny    app="^Cinny$"    space=3
yabai -m rule --add label=signal   app="^Signal$"   space=3
yabai -m rule --add label=discord  app="^Discord$"  space=3
yabai -m rule --add label=telegram app="^Telegram$" space=3
yabai -m rule --add label=slack    app="^Slack$"    space=4

yabai -m rule --apply

# Force-place already-open windows (rule --apply is unreliable on existing windows)
place_app() {
    app="$1"; target="$2"
    yabai -m query --windows | jq -r ".[] | select(.app==\"$app\") | .id" | while read -r wid; do
        yabai -m window "$wid" --space "$target" 2>/dev/null
    done
}

sleep 1
place_app "Ghostty"  1
place_app "Zen"      2
place_app "Cinny"    3
place_app "Signal"   3
place_app "Discord"  3
place_app "Telegram" 3
place_app "Slack"    4
